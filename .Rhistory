remotes::install_github("cynkra/ragent")
library(ragent)
SLIDE_DATA <- list(
# From JourneyMapping_2025_Lesson1_OperateJourneyMappingTeam.pdf (Snippet: Pages 2-4)
"1" = "HIGH-LEVEL CUSTOMER SUCCESS STRATEGY: 1. Maximize CLV. 2. Segment & treat customers by lifecycle and persona. 3. Build cross-department customer engagement plan.",
# From JourneyMapping_2025_Lesson1_OperateJourneyMappingTeam.pdf (Snippet: Pages 51-52)
"2" = "CUSTOMER SUCCESS TEAM roles include: Director, Customer Support, VP Customer Success, Sr. Support Manager, Customer Advocate, Customer Success Manager. The team's focus is on enterprise customers, handling inbound product support requests, monitoring customer health, and working with Product on self-serve features.",
# From GrowthHacking_2025_Lesson4_BlueOcean_GrowthHacking.pdf (Snippet: Page 2)
"3" = "BLUE OCEAN STRATEGY: 'Why compete when you don't have to ?' Red Ocean is 'Bloody competition to take a larger share in the market'. Blue Ocean is about 'winning without fighting'.",
# From GrowthHacking_2025_Lesson4_BlueOcean_GrowthHacking.pdf (Snippet: Page 22)
"4" = "SEQUENCE OF BLUE OCEAN STRATEGY: 1. Is there exceptional buyer utility in your business idea? 2. Is your price easily accessible to the mass of buyers? 3. Can you attain your cost target to profit at your strategic price? 4. What are the adoption hurdles in actualizing your business idea? Are you addressing them upfront?"
)
rag_tool <- function(query) {
# Simple case-insensitive search logic for demonstration
query_lower <- tolower(query)
# Search through the slide data
for (slide_num in names(SLIDE_DATA)) {
slide_content <- SLIDE_DATA[[slide_num]]
if (grepl(query_lower, tolower(slide_content))) {
# Found a match!
return(list(
answer_fragment = slide_content,
source_slide = as.integer(slide_num)
))
}
}
# If no match is found
return(list(
answer_fragment = "Information not explicitly found in slides.",
source_slide = 0L
))
}
# 3. Define the Tool Specification for the Agent
# This is how the LLM agent knows what the 'tool' does and what inputs it expects.
rag_tool_spec <- ragent::tool_spec(
rag_tool,
name = "search_slides",
description = "Searches the uploaded slide content for relevant information based on a user's query and returns the answer and the slide number where the information was found.",
arguments = list(
query = "The user's question or keyword to search for, e.g., 'Q1 revenue' or 'EMEA strategy'."
),
return_value = "A list containing the 'answer_fragment' (the text snippet) and the 'source_slide' number."
)
rm(list = ls()
)
rm(list = ls()
)
