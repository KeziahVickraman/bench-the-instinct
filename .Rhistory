tau  <- tau_simple(U_TP, U_FP)
B <- tibble(
signal = c("S+", "S−"),
s      = c(20, 80),    # conversions # TOUCH ME !!!!
f      = c(154, 376),  # non-conversions # TOUCH ME !!!!
alpha0 = 3, beta0 = 27 # TOUCH ME (using the lecture slides)
) |>
rowwise() |>
mutate(
post_mean = posterior_beta(alpha0, beta0, s, f)$mean,
EV_per_target = ev_simple(post_mean, U_TP, U_FP),
decision = ifelse(post_mean >= tau,
"ACT", "DO NOT ACT")
) |>
ungroup()
kable(B, digits = 3,
caption = sprintf("Netflix — tau = %.3f", tau)
)
