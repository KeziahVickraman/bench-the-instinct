what_if <-
tribble(
~touchpoint, ~lever, ~delta_p, ~U_TP, ~U_FP, ~currency,
"Touchpoint", "A: Send Email",   0.2,   16.0, 0.1, "SGD",
"Touchpoint", "B: Ranking Algo",  0.2,   16.0, 0.30, "SGD",
"Touchpoint", "C: Personalized Reccomender", 0.3,  16.0, 2.1, "SGD",
"Touchpoint", "D: Buy new shows", 0.3,  16.0, 3.1, "SGD",
"Touchpoint", "E: $16 Voucher",  0.3, 30.0, 16.0, "SGD") |>
mutate(
tau = tau_simple(U_TP, U_FP),
p0 = c(0.23, 0.23, 0.30, 0.30, 0.32),
p1 = p0 + delta_p,
EV0 = ev_simple(p0, U_TP, U_FP),
EV1 = ev_simple(p1, U_TP, U_FP),
dEV = EV1 - EV0
)
theme_set(theme_bw()
)
ggplot(E, aes(x = signal, y = EV_per_target)
) +
geom_col() +
geom_hline(yintercept = 0,
linetype = "dashed") +
labs(title = "Touch Point E: Renewal",
subtitle = "Reccomendation: Free 1 Month ($16 coupon)",
y = "EV (SGD)",
x = "Signal segment")
